rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reads on the "users" collection if the user is authenticated
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Example rules for other collections, such as "groups"
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
    }

    // Example rules for "posts"
    match /posts/{postId} {
      allow read, write: if request.auth != null;
    }
    
    match /stressData/{document} {
      allow read: if request.auth != null; // Ensure the user is authenticated
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }
    
    match /categories/{category} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /stress_keywords/{keyword} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /stress_logs/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /log_book/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    match /stress_detected_message/{keyword} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /stress_detected_message/{doc} {
      allow write: if request.auth != null;
    }
    
    match /chats/{chatId}/messages/{messageId} {
      allow write: if request.auth != null;
    }
  }
}